# Profit Path Backend Environment Variables
# Copy this file to .env and update values

# Application Settings
APP_NAME=Profit-Path
APP_ENV=production
DEBUG=false

# Database Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=profitpath
MONGODB_POOL_SIZE=10
MONGODB_TIMEOUT=5000

# API Configuration
API_TITLE=Profit-Path Investment API
API_VERSION=1.0.0
API_DESCRIPTION=Production-ready investment recommendation engine

# JWT Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://your-domain.com

# AI Engine Configuration
MODEL_CACHE_HOURS=24
MARKET_DATA_CACHE_MINUTES=60
BATCH_INFERENCE_SIZE=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_REAL_MARKET_DATA=true
ENABLE_ML_PREDICTIONS=true
ENABLE_DATABASE_PERSISTENCE=true
ENABLE_RECOMMENDATION_CACHING=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Market Data Configuration
STOCK_DATA_LOOKBACK_YEARS=5
VOLATILITY_WINDOW_DAYS=252
BETA_CALCULATION_PERIODS=252
